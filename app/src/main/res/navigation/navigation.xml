<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.mysawit.view.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/actionDashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.mysawit.view.DashboardFragment"
        android:label="fragment_dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/actionNewHabitFragment"
            app:destination="@id/newHabitFragment" />
    </fragment>

    <fragment
        android:id="@+id/newHabitFragment"
        android:name="com.example.mysawit.view.NewHabitFragment"
        android:label="New Habit"
        tools:layout="@layout/fragment_new_habit" />

    <activity
        android:id="@+id/mainActivity3"
        android:name="com.example.mysawit.view.MainActivity"
        android:label="activity_main"
        tools:layout="@layout/activity_main" />

</navigation>